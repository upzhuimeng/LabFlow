{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dist": "next build && electron-builder --win portable && node scripts/copy-electron-config.cjs"
  },
  "build": {
    "appId": "org.labflow.frontend",
    "productName": "LabFlowFrontend",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone/server.js",
        "to": "server/server.js"
      },
      {
        "from": ".next/standalone/package.json",
        "to": "server/package.json"
      },
      {
        "from": ".next/standalone/.next",
        "to": "server/.next"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": ".next/static",
        "to": "server/.next/static"
      },
      {
        "from": "public",
        "to": "server/public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4"
  }
}
